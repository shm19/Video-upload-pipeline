{
  "name": "vidpipe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "tsx src/api.ts",
    "worker": "tsx src/transcode-worker.ts",
    "worker:thumbnail": "tsx src/thumbnail-worker.ts",
    "worker:caption": "tsx src/caption-worker.ts",
    "relay": "tsx src/outbox-relay.ts",
    "dev": "concurrently -n api,relay,transcode,thumbnail,caption -c blue,cyan,green,magenta,yellow \"npm:api\" \"npm:relay\" \"npm:worker\" \"npm:worker:thumbnail\" \"npm:worker:caption\"",
    "start": "docker compose up -d --wait && npm run dev"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
